# Environment variables for BookMyJuice Spring Boot Application
# Copy this file to .env and replace with actual values before running

# Database Configuration
DB_USERNAME=your_db_username
DB_PASSWORD=your_secure_db_password

# Admin/Spring Security Configuration
ADMIN_USER=your_admin_username
ADMIN_PASSWORD=your_secure_admin_password

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_must_be_at_least_32_characters_long

# Webhook Configuration (for bmjServer basic auth)
WEBHOOK_USERNAME=your_webhook_username
WEBHOOK_PASSWORD=your_secure_webhook_password

# Email Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email_address
MAIL_PASSWORD=your_email_app_password
MAIL_FROM=your_email_address

# Chargebee Configuration
CHARGEBEE_SITE=your_chargebee_site_name
CHARGEBEE_API_KEY=your_chargebee_api_key
