# ============================================================
# BookMyJuice Backend - Environment Variables
# ============================================================
# Copy this file to .env and fill in actual values.
# NEVER commit .env to git.
# ============================================================

# Database
DB_USERNAME=bmj
DB_PASSWORD=replace_with_db_password
DB_HOSTNAME=localhost
DB_PORT=3306
DB_NAME=bmj_db

# Chargebee
CHARGEBEE_SITE=replace_with_chargebee_site_name
CHARGEBEE_API_KEY=replace_with_chargebee_api_key

# JWT
JWT_SECRET=replace_with_min_64_char_random_string
JWT_EXPIRATION_MS=2592000000

# Google OAuth
GOOGLE_CLIENT_ID=replace_with_google_client_id
GOOGLE_WEB_CLIENT_ID=replace_with_google_web_client_id

# SMTP / Email
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=replace_with_email
MAIL_PASSWORD=replace_with_smtp_password
MAIL_FROM=replace_with_email

# Webhook
WEBHOOK_USERNAME=webhook_user
WEBHOOK_PASSWORD=replace_with_webhook_password

# Admin
ADMIN_USER=admin
ADMIN_PASSWORD=replace_with_admin_password

